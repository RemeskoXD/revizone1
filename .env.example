# Database Connection
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://user:password@host:3306/revizone_db"

# Authentication (NextAuth.js)
# Generate a random string: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Optional: External Services (if needed later)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# SMTP (e-maily z aplikace – např. notifikace, pozvánky)
# Bez těchto proměnných sendMail() v lib/mail.ts nic neodešle (jen přeskočí).
# Na Coolify: Environment → přidej jednotlivé klíče.
# ---------------------------------------------------------------------------
# SMTP_HOST="mail.mescon.eu"
# SMTP_PORT="465"
# SMTP_SECURE="true"
#   true = port 465 (SSL), false = STARTTLS na 587 (běžné u Seznamu/Gmailu přes relay)
# SMTP_USER="qapi@mescon.eu"
# SMTP_PASS=""
# SMTP_FROM="Revizone <noreply@domena.cz>"
# Volitelné:
# SMTP_TLS_REJECT_UNAUTHORIZED="true"
